**** begin user architecture code
.lib /foss/pdks/sky130A/libs.tech/combined/sky130.lib.spice tt
**** end user architecture code
**** begin user architecture code



* ngspice commands
.param WN=1
.options savecurrents
.include test_sweep_mos_w.save
.dc v2 0 1.8 0.01
.control
  let start_w = 1
  let stop_w = 90
  let delta_w = 5
  let w_act = start_w
  let new_vth = 0.3
  while w_act le stop_w
    alterparam WN = $&w_act
    reset
    ** example for changing a model param
    * altermod @m.xm1.msky130_fd_pr__nfet_01v8[vth0]=$&new_vth
    save all
    save @m.xm1.msky130_fd_pr__nfet_01v8[gm]
    save @m.xm1.msky130_fd_pr__nfet_01v8[W]
    run
    remzerovec
    write test_sweep_mos_w.raw
    let w_act = w_act + delta_w
    set appendwrite
  end
.endc


**** end user architecture code
XM1 D G GND GND sky130_fd_pr__nfet_01v8 L=0.15 W=WN nf=1 ad='int((1 + 1)/2) * WN / 1 * 0.29' as='int((1 + 2)/2) * WN / 1 * 0.29' pd='2*int((1 + 1)/2) * (WN / 1 + 0.29)'
