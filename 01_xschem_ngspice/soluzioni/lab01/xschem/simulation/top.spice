VICM VCM GND dc 0.85 ac 0
C1 net1 GND 5p m=1
V3 VDD GND 1.8
**** begin user architecture code


.options savecurrents
.control
 let runs=1000
 let r=0
 dowhile r < runs
   reset
   op
   let vdiff = v(vm,vcm)
   let run=r
   remzerovec
   write montecarlo_mismatch_sim.raw
   set appendwrite
   print v(vm,vcm)
   let r = r + 1
 end
.endc


**** end user architecture code
