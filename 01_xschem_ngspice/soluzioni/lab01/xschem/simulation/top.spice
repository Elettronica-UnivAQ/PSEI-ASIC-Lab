* ngspice commands
.param L=1
.options savecurrents
.control
  let start_l = 1
  let stop_l = 10
  let delta_l = 1
  let l_act = start_l
  while l_act le stop_l
    alterparam L = $&l_act
    reset
    save all
    op
    remzerovec
    write test_sweep_res_l.raw
    let l_act = l_act + delta_l
    set appendwrite
  end
.endc


